{
  "name": "evcc-grafana-dashboards",
  "version": "1.0.0",
  "description": "EVCC Dashboard mit Grafana für 2 Loadpoints und 2 Fahrzeuge. Loadpoints und Fahrzeuge können bei Bedarf einfach reduziert werden.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "node scripts/test/local-checks.mjs",
    "test:ci": "node scripts/test/local-checks.mjs",
    "test:energy-validation": "node scripts/test/energy-validation.mjs",
    "test:forgejo-actions": "node scripts/test/forgejo-actions-check.mjs",
    "test:localization-idempotency": "node scripts/test/localization-idempotency-check.mjs --family=vm",
    "test:powershell-compat": "node scripts/test/powershell-deployer-compat.mjs",
    "test:query-readback": "node scripts/test/dashboard-query-readback.mjs --docker",
    "test:render-e2e": "node scripts/test/render-e2e.mjs",
    "test:rollup-e2e": "node scripts/test/local-checks.mjs --rollup-e2e",
    "test:rollup-path": "node scripts/test/rollup-path-check.mjs",
    "test:cross-platform": "node scripts/test/cross-platform-audit.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/endurance1968/evcc-grafana-dashboards.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0"
  }
}
