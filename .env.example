# Grafana API
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_API_TOKEN=replace-with-service-account-token

# Browser automation login (only required for screenshots)
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Datasource UID mapping used during import and test automation
GRAFANA_DS_EVCC_INFLUXDB_UID=replace-with-uid
GRAFANA_DS_EVCC_AGGREGRATIONS_UID=replace-with-uid
GRAFANA_DS_VM_EVCC_UID=replace-with-uid

# Optional settings
GRAFANA_TEST_FOLDER_UID=evcc-l10n-test
GRAFANA_TEST_FOLDER_TITLE=EVCC Localization Test
GRAFANA_DASHBOARD_TITLE_PREFIX=
GRAFANA_TIME_FROM=now-24h
GRAFANA_TIME_TO=now
GRAFANA_SCREENSHOT_WAIT_MS=3500

