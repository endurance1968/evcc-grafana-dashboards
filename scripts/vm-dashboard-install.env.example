# EVCC VM dashboard installer defaults
# Copy to vm-dashboard-install.env and adjust as needed.
# For the first install, only GRAFANA_URL and GRAFANA_API_TOKEN usually need changes.

GRAFANA_URL=http://localhost:3000
GRAFANA_API_TOKEN=
GRAFANA_DS_VM_EVCC_UID=vm-evcc

# Deploy target
GRAFANA_FOLDER_UID=evcc
GRAFANA_FOLDER_TITLE=EVCC

# Dashboard source
DASHBOARD_SOURCE_MODE=github
GITHUB_REPO=endurance1968/evcc-grafana-dashboards
GITHUB_REF=main
DASHBOARD_LANGUAGE=en
DASHBOARD_VARIANT=gen
# Only needed for DASHBOARD_SOURCE_MODE=local
# DASHBOARD_LOCAL_DIR=

# Behavior
PURGE=false


