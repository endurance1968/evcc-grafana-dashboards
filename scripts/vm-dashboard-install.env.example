# EVCC VM dashboard installer defaults
# Copy to vm-dashboard-install.env and adjust as needed.
# For the first install, only GRAFANA_URL and GRAFANA_API_TOKEN usually need changes.
# Grafana 12/13: use a service-account token in GRAFANA_API_TOKEN.
# If an old API key fails after a Grafana upgrade, generate a new service-account token.

GRAFANA_URL=http://localhost:3000
GRAFANA_AUTH_MODE=auto
GRAFANA_API_TOKEN=
# Optional alias for clarity. If GRAFANA_API_TOKEN is empty, deployers use this value.
# GRAFANA_SERVICE_ACCOUNT_TOKEN=
# Optional fallback for local/admin recovery when token auth is not available.
# GRAFANA_AUTH_MODE=basic
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=
GRAFANA_DS_VM_EVCC_UID=vm-evcc

# Deploy target
GRAFANA_FOLDER_UID=evcc
GRAFANA_FOLDER_TITLE=EVCC

# Dashboard source
DASHBOARD_SOURCE_MODE=github
GITHUB_REPO=endurance1968/evcc-grafana-dashboards
GITHUB_REF=main
DASHBOARD_LANGUAGE=en
DASHBOARD_VARIANT=gen
# Only needed for DASHBOARD_SOURCE_MODE=local
# DASHBOARD_LOCAL_DIR=

# Behavior
PURGE=false

# Optional dashboard variable overrides. Leave empty to keep the defaults from the dashboard JSON files.
# DASHBOARD_FILTER_PEAK_POWER_LIMIT=30000
# DASHBOARD_ENERGY_SAMPLE_INTERVAL=30s
# DASHBOARD_TARIFF_PRICE_INTERVAL=15m
# DASHBOARD_INSTALLED_WATT_PEAK=20
# DASHBOARD_FILTER_LOADPOINT_BLOCKLIST=^none$
# DASHBOARD_FILTER_EXT_BLOCKLIST=^none$
# DASHBOARD_FILTER_AUX_BLOCKLIST=^none$
# DASHBOARD_FILTER_VEHICLE_BLOCKLIST=^none$
# DASHBOARD_EVCC_URL=http://home:7070/#/
# DASHBOARD_PORTAL_TITLE=Solarman
# DASHBOARD_PORTAL_URL=https://globalhome.solarmanpv.com/plant/infos/data
