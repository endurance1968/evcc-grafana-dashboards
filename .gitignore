.DS_Store
# Local environment files
.env
.env.local

# Test artifacts
tests/artifacts/*
!tests/artifacts/screenshots/
tests/artifacts/screenshots/*
!tests/artifacts/screenshots/vm/
!tests/artifacts/screenshots/vm/**

# Playwright cache/state
.playwright/

# Generated localization audit candidates
dashboards/localization/missing-*.exact.json
dashboards/influx-legacy/localization/missing-*.exact.json

# Local Node dependencies
node_modules/

# Python cache
__pycache__/
*.pyc

# Local backups and temporary work files
tmp/
# Local external energy comparison caches
data/energy-comparison/tibber/*
!data/energy-comparison/tibber/.gitkeep
data/energy-comparison/vrm/*
!data/energy-comparison/vrm/.gitkeep

